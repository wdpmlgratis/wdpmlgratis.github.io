---
// src/components/Link.astro
// Astro Paper biasanya tidak punya utility 'cn' secara default, 
// jadi kita pakai template literal biasa agar aman.

type Props = {
  href: string;
  external?: boolean;
  underline?: boolean;
  class?: string;
}

const { href, external, underline = true, class: className, ...rest } = Astro.props;
---

<a 
  href={href} 
  target={ external ? "_blank" : "_self" } 
  rel={ external ? "noopener noreferrer" : "" }
  class:list={[
    "hover:text-skin-accent transition-colors duration-300 ease-in-out",
    underline && "underline underline-offset-4 decoration-dashed decoration-1",
    className
  ]}
  {...rest}>
  <slot/>
</a>